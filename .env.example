# Copy to .env (gitignored). Compose loads it into the api container automatically.

# eBay Developer credentials (https://developer.ebay.com — founder has an account)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# sandbox | production
EBAY_ENV=sandbox
# Marketplace for Browse API searches (US/USD only for MVP)
EBAY_MARKETPLACE_ID=EBAY_US
# Flat final-value fee rate applied to the estimated value (~13.25% typical media rate)
EBAY_FEE_RATE=0.1325
# Hard daily stop for outbound eBay API calls (50% of the 5,000/day app quota)
EBAY_DAILY_CALL_BUDGET=2500

# Vision LLM for photo item identification (post-barcode phase)
ANTHROPIC_API_KEY=

# Flip/rip cutoff in USD when the user hasn't set one
PROFIT_THRESHOLD_DEFAULT=10

# Flat shipping estimate in cents until weight/category estimation lands
SHIPPING_FLAT_CENTS=500
# How long a computed valuation is served from cache
VALUATION_CACHE_TTL_HOURS=24
# Per-client (IP) daily lookup cap
LOOKUP_DAILY_CAP=50

PORT=3000
