# Copy to .env (gitignored). Compose loads it into the api container automatically.

# eBay Developer credentials (https://developer.ebay.com — founder has an account)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# sandbox | production
EBAY_ENV=sandbox

# Vision LLM for photo item identification (post-barcode phase)
ANTHROPIC_API_KEY=

# Flip/rip cutoff in USD when the user hasn't set one
PROFIT_THRESHOLD_DEFAULT=10

PORT=3000
